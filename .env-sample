# =====================================================
# AI Services
# =====================================================
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACE_TOKEN=hf_your_huggingface_token_here

# =====================================================
# Database (CockroachDB Serverless)
# =====================================================
# Format: postgresql+psycopg2://username:password@host:26257/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg2://username:password@host.aws-ap-south-1.cockroachlabs.cloud:26257/transcribeflow?sslmode=require

# =====================================================
# Cloudflare R2 Storage
# =====================================================
R2_ACCOUNT_ID=your_32_char_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=transcribeflow

# =====================================================
# JWT / Security
# =====================================================
SECRET_KEY=generate_a_long_random_string_here
JWT_SECRET_KEY=generate_another_long_random_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =====================================================
# App Settings
# =====================================================
# Set this to your Render deployment URL after deploying
FRONTEND_URL=https://your-app-name.onrender.com
MAX_FILE_SIZE_MB=25